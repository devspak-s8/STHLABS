rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for monitored sites
    function isValidMonitoredSite(data) {
      return data.keys().hasAll(['ownerId', 'url', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.url is string && data.url.size() >= 4 && data.url.size() <= 1000 &&
             isValidId(data.ownerId);
    }

    // Validation for audit logs
    function isValidAuditLog(data) {
      return data.keys().hasAll(['timestamp']) &&
             data.timestamp is timestamp;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.uid == "mZIuMPDgDJdSqNqOXtTtNnqyADt1" || 
              (request.auth.token.email == "apatirasulayman@gmail.com" && request.auth.token.email_verified == true));
    }

    match /monitored_sites/{siteId} {
      // Allow the designated admin all access to verified sites
      allow read, write: if isAdmin();

      match /audits/{auditId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
