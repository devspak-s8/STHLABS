rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for monitored sites
    function isValidMonitoredSite(data) {
      return data.keys().hasAll(['ownerId', 'url', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.url is string && data.url.size() >= 4 && data.url.size() <= 1000 &&
             isValidId(data.ownerId);
    }

    // Validation for audit logs
    function isValidAuditLog(data) {
      return data.keys().hasAll(['timestamp']) &&
             data.timestamp is timestamp;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "mZIuMPDgDJdSqNqOXtTtNnqyADt1";
    }

    match /monitored_sites/{siteId} {
      // Create: Must be the admin
      allow create: if isAdmin() && 
                      isValidMonitoredSite(request.resource.data) &&
                      request.resource.data.createdAt == request.time;
      
      // Read: Only the admin can see their own sites
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      
      // Update: Admin can update
      allow update: if isAdmin() && 
                      isValidMonitoredSite(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isAdmin();

      match /audits/{auditId} {
        allow get, list: if isOwner(get(/databases/$(database)/documents/monitored_sites/$(siteId)).data.ownerId);
        allow create: if isVerified() && 
                        isOwner(get(/databases/$(database)/documents/monitored_sites/$(siteId)).data.ownerId) && 
                        isValidAuditLog(request.resource.data);
      }
    }
  }
}
